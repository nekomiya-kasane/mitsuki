        // ============================================================
        // WASM (Emscripten + WebGPU) - Browser debugging
        // ============================================================
        {
            "name": "[WASM] Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8888/bin/index.html",
            "webRoot": "${workspaceFolder}/build/wasm",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "/*": "${workspaceFolder}/*"
            },
            "preLaunchTask": "serve-wasm"
        },
        {
            "name": "[WASM] Edge",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8888/bin/index.html",
            "webRoot": "${workspaceFolder}/build/wasm",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "/*": "${workspaceFolder}/*"
            },
            "preLaunchTask": "serve-wasm"
        },
        // ============================================================
        // Input-based configuration (select exe at runtime)
        // ============================================================
        {
            "name": "[Full] Select Executable...",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug-full/${input:fullExe}",
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "fullExe",
            "type": "pickString",
            "description": "Select executable from debug-full build",
            "options": [
                "test_window_manager.exe",
                "test_window_manager_glfw.exe",
                "test_window_manager_spec.exe",
                "test_event_simulator.exe",
                "test_structured_logger.exe",
