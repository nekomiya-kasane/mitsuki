                "test_rhi_command_buffer.exe",
                "test_rhi_pipeline.exe",
                "test_rhi_sync.exe",
                "test_rhi_accel_struct.exe",
                "test_rhi_swapchain.exe",
                "test_rhi_query.exe",
                "test_rhi_integration.exe",
                "window_manager_demo.exe",
                "logger_demo.exe",
                "rhi_triangle_demo.exe"
            ],
