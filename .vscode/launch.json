            "cwd": "${workspaceFolder}",
            "env": {}
        },
        // ============================================================
        // WASM (Emscripten + WebGPU) - Browser debugging
        // ============================================================
        {
            "name": "[WASM] Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8888/bin/index.html",
            "webRoot": "${workspaceFolder}/build/wasm",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "/*": "${workspaceFolder}/*"
            },
            "preLaunchTask": "serve-wasm"
        },
        {
            "name": "[WASM] Edge",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8888/bin/index.html",
            "webRoot": "${workspaceFolder}/build/wasm",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "/*": "${workspaceFolder}/*"
            },
            "preLaunchTask": "serve-wasm"
        },
        // ============================================================
        // Input-based configurations (select exe at runtime)
        // ============================================================
        {
            "name": "[Vulkan] Select Executable...",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug-vulkan/${input:vulkanExe}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {}
        },
        {
            "name": "[D3D12] Select Executable...",
            "type": "lldb",
