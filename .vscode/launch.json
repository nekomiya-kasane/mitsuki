            "request": "launch",
            "program": "${workspaceFolder}/build/debug-webgpu/${input:webgpuExe}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {}
        }
    ],
    "inputs": [
        {
            "id": "vulkanExe",
            "type": "pickString",
            "description": "Select Vulkan executable",
            "options": [
                "test_structured_logger.exe",
                "test_event_simulator.exe",
                "test_window_manager.exe",
                "logger_demo.exe",
                "bin/tapioca_demo.exe"
            ],
            "default": "test_window_manager.exe"
        },
        {
            "id": "d3d12Exe",
            "type": "pickString",
            "description": "Select D3D12 executable",
            "options": [
                "test_structured_logger.exe",
                "test_event_simulator.exe",
                "test_window_manager.exe"
            ],
            "default": "test_window_manager.exe"
        },
        {
            "id": "webgpuExe",
            "type": "pickString",
            "description": "Select WebGPU executable",
            "options": [
                "test_structured_logger.exe",
                "test_event_simulator.exe",
                "test_window_manager.exe",
                "test_window_manager_spec.exe",
                "test_surface_integration.exe",
                "rhi_triangle_demo.exe"
            ],
